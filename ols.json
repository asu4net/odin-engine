{
	"$schema": "https://raw.githubusercontent.com/DanielGavin/ols/master/misc/ols.schema.json",
	"collections": [
		{ "name": "game", "path": "./game" }
	],
	"enable_semantic_tokens": false,
	"enable_document_symbols": true,
	"enable_hover": true,
	"enable_snippets": true,
	"profile": "debug",
	"profiles": [
		{ 
            "name": "debug", 
            "checker_path": [
                "./", 
                "./game" 
            ], 
            "defines": { 
                "ODIN_DEBUG": "true"
            }
        }
	]
}